{
  "name": "mtg-agent",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    ".opencode"
  ],
  "scripts": {
    "db:sqlite:migration:apply": "bun packages/sqlite/src/apply-migrations.ts",
    "db:sqlite:migration:generate": "bun run --cwd packages/sqlite drizzle-kit generate",
    "import:collection": "bun packages/cli/src/import-collection.ts",
    "import:scryfall": "bun packages/cli/src/import-scryfall.ts",
    "test": "bun test",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.17.8",
    "@types/bun": "1.3.14",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.3"
  }
}
