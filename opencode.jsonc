{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "mtcg": {
            "type": "local",
            "enabled": true,
            "command": [
                "bun",
                "./tools/mtcg-mcp/index.ts",
                "-d",
                "./data/ManaBox_Collection.csv",
                "-b",
                "./data/mtcg.db"
            ],
        }
    }
}